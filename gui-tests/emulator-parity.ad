# Stock Emulator tool — open from Tool Chest.
context platform=macos timeout=120000
env APP_TARGET="${APP_TARGET}"
open "${APP_TARGET}" --relaunch
wait "id=\"ghidra.vibe.project\" || label=\"Tool Chest\"" 25000
click "id=\"ghidra.vibe.project.tool.emulator\" || label=\"Emulator\""
wait "id=\"ghidra.vibe.emulator\" || label=\"Emulate\"" 10000
snapshot -i
is exists "id=\"ghidra.vibe.emulator\" || label=\"Emulate\""
click "id=\"ghidra.vibe.emulator.toolbar.emulate\" || label=\"Emulate\""
wait "id=\"ghidra.vibe.status.message\" || label=\"Status message\"" 5000
snapshot -i
close
