# Stock Version Tracking tool — open from Tool Chest.
context platform=macos timeout=120000
env APP_TARGET="${APP_TARGET}"
open "${APP_TARGET}" --relaunch
wait "id=\"ghidra.vibe.project\" || label=\"Tool Chest\"" 25000
click "id=\"ghidra.vibe.project.tool.version_tracking\" || label=\"Version Tracking\""
wait "id=\"ghidra.vibe.version_tracking\" || label=\"Create Session\"" 10000
snapshot -i
is exists "id=\"ghidra.vibe.version_tracking\" || label=\"Create Session\""
click "id=\"ghidra.vibe.version_tracking.toolbar.create_session\" || label=\"Create Session\""
wait "id=\"ghidra.vibe.status.message\" || label=\"Status message\"" 5000
snapshot -i
close
