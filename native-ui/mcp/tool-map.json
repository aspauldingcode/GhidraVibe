{
  "version": 1,
  "description": "Every native UI action/provider maps to analysis MCP (:8089) and/or vibe MCP (:8092).",
  "servers": {
    "analysis": {
      "env": "GHIDRA_MCP_URL",
      "default": "http://127.0.0.1:8089"
    },
    "vibe": {
      "env": "GHIDRA_VIBE_MCP_EXT_URL",
      "default": "http://127.0.0.1:8092"
    },
    "gui": {
      "env": "GHIDRA_VIBE_GUI_URL",
      "default": "http://127.0.0.1:8091"
    },
    "debugger": {
      "env": "GHIDRA_MCP_DEBUGGER_URL",
      "default": "http://127.0.0.1:8099"
    }
  },
  "actions": {
    "auto_analyze": {
      "server": "analysis",
      "tool": "run_analysis"
    },
    "goto": {
      "server": "analysis",
      "tool": "disassemble_function"
    },
    "undo": {
      "server": "vibe",
      "tool": "vibe_undo"
    },
    "redo": {
      "server": "vibe",
      "tool": "vibe_redo"
    },
    "nav_back": {
      "server": "vibe",
      "tool": "vibe_nav_back"
    },
    "nav_fwd": {
      "server": "vibe",
      "tool": "vibe_nav_forward"
    },
    "clear_selection": {
      "server": "vibe",
      "tool": "vibe_clear_selection"
    },
    "start_mcp": {
      "server": "analysis",
      "tool": "check_connection"
    },
    "mcp_health": {
      "server": "analysis",
      "tool": "check_connection"
    },
    "fetch_functions": {
      "server": "analysis",
      "tool": "list_functions"
    },
    "decompile": {
      "server": "analysis",
      "tool": "decompile_function"
    },
    "rag_index": {
      "server": "vibe",
      "tool": "rag_index"
    },
    "import_apple": {
      "server": "vibe",
      "tool": "malimite_analyze"
    },
    "dyld_open": {
      "server": "vibe",
      "tool": "dyld_list_images"
    },
    "open_shared_cache": {
      "server": "vibe",
      "tool": "dyld_list_images"
    },
    "open_app_bundle": {
      "server": "vibe",
      "tool": "malimite_open_bundle"
    },
    "listing_disassemble": {
      "server": "vibe",
      "tool": "listing_disassemble"
    },
    "listing_define_data": {
      "server": "vibe",
      "tool": "listing_define_data"
    },
    "listing_clear_code": {
      "server": "vibe",
      "tool": "listing_clear_code"
    },
    "listing_create_label": {
      "server": "vibe",
      "tool": "listing_create_label"
    },
    "listing_create_function": {
      "server": "vibe",
      "tool": "listing_create_function"
    },
    "listing_add_bookmark": {
      "server": "vibe",
      "tool": "listing_add_bookmark"
    },
    "listing_create_structure": {
      "server": "vibe",
      "tool": "listing_create_structure"
    },
    "save_program": {
      "server": "vibe",
      "tool": "vibe_proxy_analysis"
    },
    "bsim_search": null,
    "bsim_overview": null,
    "edit_cut": null,
    "edit_copy": {
      "server": "vibe",
      "tool": "edit_copy"
    },
    "edit_paste": null,
    "search_memory": {
      "server": "vibe",
      "tool": "search_memory"
    },
    "open_debugger": null,
    "open_emulator": null,
    "provider_create": {
      "server": "vibe",
      "tool": "provider_create"
    },
    "debugger_control": {
      "server": "vibe",
      "tool": "debugger_control"
    },
    "vt_session": {
      "server": "vibe",
      "tool": "vt_session"
    }
  },
  "providers": {
    "listing": {
      "server": "analysis",
      "tool": "disassemble_function"
    },
    "decompiler": {
      "server": "analysis",
      "tool": "decompile_function"
    },
    "program_tree": {
      "server": "analysis",
      "tool": "list_project_files"
    },
    "symbol_tree": {
      "server": "analysis",
      "tool": "list_namespaces"
    },
    "data_types": {
      "server": "analysis",
      "tool": "list_data_types"
    },
    "functions": {
      "server": "analysis",
      "tool": "list_functions"
    },
    "strings": {
      "server": "analysis",
      "tool": "list_strings"
    },
    "memory_map": {
      "server": "analysis",
      "tool": "list_segments"
