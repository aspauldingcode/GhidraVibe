    },
    "symbol_references": {
      "server": "analysis",
      "tools": [
        "get_xrefs_to",
        "get_xrefs_from"
      ]
    },
    "comments": {
      "server": "vibe",
      "tool": "vibe_list_comments"
    },
    "checksum": {
      "server": "analysis",
      "tool": "get_function_hash"
    },
    "datatype_preview": {
      "server": "analysis",
      "tool": "get_struct_layout"
    },
    "disassembled_view": {
      "server": "analysis",
      "tool": "disassemble_function"
    },
    "entropy": {
      "server": "vibe",
      "tool": "vibe_list_entropy"
    },
    "overview": {
      "server": "vibe",
      "tool": "vibe_list_entropy"
    },
    "equates": {
      "server": "vibe",
      "tool": "vibe_list_equates"
    },
    "relocations": {
      "server": "vibe",
      "tool": "vibe_list_relocations"
    },
    "registers": {
      "server": "vibe",
      "tool": "vibe_list_registers"
    },
    "function_tags": {
